        "rageSoundOverride": {"type": "string", "description": "Rage sound override path"},

        "_section_special": {"type": "null", "description": "=== SPECIAL ABILITIES (EAS_*) ==="},
        "special1": {"type": "string", "description": "Special ability slot 1"},
        "special2": {"type": "string", "description": "Special ability slot 2"},
        "special3": {"type": "string", "description": "Special ability slot 3"},
        "special4": {"type": "string", "description": "Special ability slot 4"},
        "resource": {"type": "string", "description": "Resource type (resourceTable)"},

        "_section_limits": {"type": "null", "description": "=== CLASS LIMITS & SPAWNING ==="},
        "classNumberLimit": {"type": "integer", "description": "Max players using this class (0=unlimited)", "default": 0},
        "respawnWait": {"type": "integer", "description": "Respawn wait time", "default": 0},
        "respawnCustomTime": {"type": "integer", "description": "Custom respawn time (ms)", "default": -1},
        "extralives": {"type": "integer", "description": "Extra lives beyond default", "default": 0},

        "_section_misc": {"type": "null", "description": "=== MISCELLANEOUS ==="},
