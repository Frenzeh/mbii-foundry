#!/usr/bin/env bash
#
# MBII Foundry — pre-push identity guard.
#
# Rejects a push if:
#   1. The configured Git author isn't Frenzy.
#   2. The remote URL isn't the canonical Frenzeh remote.
#
# This is a defense-in-depth catch, not a security boundary — it can be
# bypassed with `git push --no-verify`. Its purpose is to prevent
# honest mistakes: pushing from a dev session that was configured under
# the wrong Git identity, or to the wrong fork.
#
# Install:
#   ./tools/git-hooks/install.sh
# Which sets:
#   git config core.hooksPath tools/git-hooks

set -euo pipefail

# --- Expected identity ---
EXPECTED_NAME="Frenzy"
EXPECTED_EMAIL="elitewarriors@protonmail.com"
EXPECTED_REMOTE_PATTERN='github\.com.*Frenzeh/mbii-foundry(\.git)?$'

# --- Actual identity ---
remote_name="$1"
remote_url="$2"

actual_name=$(git config --get user.name || true)
actual_email=$(git config --get user.email || true)

fail() {
    echo ""
    echo "  ┌─ PUSH BLOCKED ─────────────────────────────────────────────┐"
    echo "  │"
    for line in "$@"; do
        echo "  │  $line"
    done
    echo "  │"
    echo "  │  Override (not recommended): git push --no-verify"
    echo "  └────────────────────────────────────────────────────────────┘"
    echo ""
    exit 1
}

# --- Identity checks ---
if [[ "$actual_name" != "$EXPECTED_NAME" ]]; then
    fail "Git user.name is '$actual_name' — expected '$EXPECTED_NAME'." \
         "Fix: git config user.name '$EXPECTED_NAME'"
fi

if [[ "$actual_email" != "$EXPECTED_EMAIL" ]]; then
    fail "Git user.email is '$actual_email' — expected '$EXPECTED_EMAIL'." \
         "Fix: git config user.email '$EXPECTED_EMAIL'"
fi

# --- Remote check ---
if ! [[ "$remote_url" =~ $EXPECTED_REMOTE_PATTERN ]]; then
    fail "Pushing to an unexpected remote:" \
         "  $remote_url" \
         "Expected a URL matching: Frenzeh/mbii-foundry" \
         "If this is a legitimate new remote, update EXPECTED_REMOTE_PATTERN."
fi

# --- Signed-commit check ---
# If signing is enabled for this repo, make sure the most recent commit
# actually got signed (catches the "forgot to rebase after enabling
# signing" case).
signing=$(git config --get commit.gpgsign || echo false)
if [[ "$signing" == "true" ]]; then
    # The range of commits being pushed comes in on stdin. Check each.
    while read -r local_ref local_sha remote_ref remote_sha; do
        if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
            continue  # deleting a branch, nothing to check
        fi
        # Range of commits being introduced by this push.
        # - Existing ref with a known remote_sha: straightforward A..B range.
        # - New ref (branch or tag): diff against everything already
        #   reachable via any ref on this remote, so pushing a tag that
        #   points to a commit already on origin doesn't re-scan the
        #   whole history back to the root (and flag ancestors that
        #   predate this hook). Falls back to the raw tip if the
        #   remote has no refs yet (fresh repo).
        if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
            if git rev-parse --verify --quiet "refs/remotes/${remote_name}/HEAD" >/dev/null \
                || git for-each-ref --format='%(refname)' "refs/remotes/${remote_name}/" | read -r _; then
                range="$local_sha --not --remotes=${remote_name}"
            else
                range="$local_sha"
            fi
        else
            range="$remote_sha..$local_sha"
        fi
        # Look at the raw commit object for a gpgsig header. This is
        # more reliable than `%G?` because the latter returns N when
        # the user has no allowedSignersFile configured for local
        # verification, even if the commit IS signed. GitHub verifies
        # against the registered signing key server-side.
        unsigned=""
        for sha in $(git rev-list $range); do
            if ! git cat-file -p "$sha" | head -20 | grep -q "^gpgsig "; then
                unsigned+="$sha"$'\n'
            fi
        done
        if [[ -n "$unsigned" ]]; then
            fail "Unsigned commits in push:" \
                 "$(echo "$unsigned" | head -5 | sed 's/^/  /')" \
                 "Sign them with: git rebase --exec 'git commit --amend --no-edit -S' <base>"
        fi
    done
fi

exit 0
