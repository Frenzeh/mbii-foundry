{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mbch_schema_v2.json",
  "title": "MBII Character Class Definition (.mbch) - Complete Schema",
  "description": "Comprehensive schema for MBII Full Authentic character files. ALL fields from bg_saga.c BG_SiegeParseClassFile().",
  "version": "2.0.0",
  "sourceReference": "moviebattles/game/bg_saga.c lines 2142-2890",

  "definitions": {
    "ClassInfo": {
      "type": "object",
      "description": "Main character class definition block - ClassInfo { }",
      "properties": {

        "_section_identity": {"type": "null", "description": "=== IDENTITY & BASIC INFO ==="},
        "name": {
          "type": "string",
          "description": "Internal class name (e.g., '_H_C1_JSage')",
          "maxLength": 64
        },
        "MBClass": {
          "type": "string",
          "description": "Base class type - determines inherent abilities",
          "enum": ["MB_CLASS_NOCLASS", "MB_CLASS_SOLDIER", "MB_CLASS_TROOPER", "MB_CLASS_COMMANDER",
                   "MB_CLASS_ELITETROOPER", "MB_CLASS_SITH", "MB_CLASS_JEDI", "MB_CLASS_BOUNTY_HUNTER",
                   "MB_CLASS_HERO", "MB_CLASS_SBD", "MB_CLASS_WOOKIE", "MB_CLASS_DROIDEKA",
                   "MB_CLASS_CLONETROOPER", "MB_CLASS_MANDALORIAN", "MB_CLASS_ARCTROOPER",
                   "MB_CLASS_REDACTED_01", "MB_CLASS_REDACTED_02", "MB_CLASS_REDACTED_03", "MB_CLASS_REDACTED_04",
                   "MB_CLASS_REDACTED_05", "MB_CLASS_REDACTED_06", "MB_CLASS_REDACTED_07",
                   "MB_CLASS_REDACTED_08", "MB_CLASS_REDACTED_09", "MB_CLASS_REDACTED_10"]
        },

        "_section_model": {"type": "null", "description": "=== MODEL & APPEARANCE ==="},
        "model": {"type": "string", "description": "Primary model path (e.g., 'cultist')"},
        "skin": {"type": "string", "description": "Primary skin name", "default": "default"},
        "modelscale": {"type": "number", "description": "Model scale multiplier", "default": 1.0},
        "soundset": {"type": "string", "description": "Voice/sound set override"},

        "_section_model_variants": {"type": "null", "description": "=== MODEL VARIANTS (up to MAX_SIEGE_VARIANTS) ==="},
        "model_1": {"type": "string", "description": "Model variant 1"},
        "model_2": {"type": "string", "description": "Model variant 2"},
        "model_3": {"type": "string", "description": "Model variant 3"},
        "skin_1": {"type": "string", "description": "Skin variant 1"},
        "skin_2": {"type": "string", "description": "Skin variant 2"},
        "skin_3": {"type": "string", "description": "Skin variant 3"},

        "_section_colors": {"type": "null", "description": "=== CUSTOM RGB COLORS ==="},
        "customred": {"type": "number", "description": "Custom red color (0.0-1.0)", "default": 1.0},
        "customgreen": {"type": "number", "description": "Custom green color (0.0-1.0)", "default": 1.0},
        "customblue": {"type": "number", "description": "Custom blue color (0.0-1.0)", "default": 1.0},
        "customred_1": {"type": "number", "description": "Variant 1 red"},
        "customgreen_1": {"type": "number", "description": "Variant 1 green"},
        "customblue_1": {"type": "number", "description": "Variant 1 blue"},
        "customred_2": {"type": "number", "description": "Variant 2 red"},
        "customgreen_2": {"type": "number", "description": "Variant 2 green"},
        "customblue_2": {"type": "number", "description": "Variant 2 blue"},
        "userRGB": {"type": "integer", "description": "Enable user RGB selection (0/1)", "default": 0},
        "userRGB_1": {"type": "integer", "description": "User RGB for variant 1"},
        "userRGB_2": {"type": "integer", "description": "User RGB for variant 2"},

        "_section_ui": {"type": "null", "description": "=== UI SHADERS & ICONS ==="},
        "uishader": {"type": "string", "description": "Main UI portrait shader path"},
        "uishader_1": {"type": "string", "description": "UI shader variant 1"},
        "uishader_2": {"type": "string", "description": "UI shader variant 2"},
        "uishader_3": {"type": "string", "description": "UI shader variant 3"},
        "uiglobal": {"type": "string", "description": "Global UI shader (conquest)"},
        "uioverlay": {"type": "string", "description": "UI overlay shader"},
        "uioverlay_l": {"type": "string", "description": "UI overlay left"},
        "uioverlay_c": {"type": "string", "description": "UI overlay center"},
        "uioverlay_r": {"type": "string", "description": "UI overlay right"},

        "_section_saber": {"type": "null", "description": "=== SABER CONFIGURATION ==="},
        "saber1": {"type": "string", "description": "Primary saber hilt name"},
        "saber2": {"type": "string", "description": "Secondary saber hilt (dual wield)"},
        "sabercolor": {"type": ["integer", "string"], "description": "Primary saber color (0-8 or HSL decimal)"},
        "saber2color": {"type": ["integer", "string"], "description": "Secondary saber color"},
        "saberstyle": {"type": "string", "description": "Pipe-separated saber styles (SS_*)"},
        "saberDamage": {"type": "integer", "description": "Saber damage modifier", "default": 0},
        "saberThrowDamage": {"type": "integer", "description": "Saber throw damage modifier", "default": 0},
        "saberMaxChain": {"type": "integer", "description": "Max saber chain hits", "default": 0},

        "_section_saber_variants": {"type": "null", "description": "=== SABER VARIANTS ==="},
        "saber1_1": {"type": "string", "description": "Saber1 variant 1"},
        "saber1_2": {"type": "string", "description": "Saber1 variant 2"},
        "saber2_1": {"type": "string", "description": "Saber2 variant 1"},
        "saber2_2": {"type": "string", "description": "Saber2 variant 2"},
        "sabercolor_1": {"type": ["integer", "string"], "description": "Saber color variant 1"},
        "sabercolor_2": {"type": ["integer", "string"], "description": "Saber color variant 2"},
        "saber2color_1": {"type": ["integer", "string"], "description": "Saber2 color variant 1"},
        "saber2color_2": {"type": ["integer", "string"], "description": "Saber2 color variant 2"},
        "saberstyle_1": {"type": "string", "description": "Saber style variant 1"},
        "saberstyle_2": {"type": "string", "description": "Saber style variant 2"},

        "_section_equipment": {"type": "null", "description": "=== EQUIPMENT & LOADOUT ==="},
        "weapons": {"type": "string", "description": "Pipe-separated weapons (WP_*)"},
        "holdables": {"type": "string", "description": "Pipe-separated holdable items (HI_*)"},
        "powerups": {"type": "string", "description": "Pipe-separated powerups"},
        "forcepowers": {"type": "string", "description": "Force powers with levels (FP_*,level)"},
        "attributes": {"type": "string", "description": "Attributes with levels (MB_ATT_*,level)"},
        "classflags": {"type": "string", "description": "Pipe-separated class flags (CFL_*)"},

        "_section_stats_health": {"type": "null", "description": "=== HEALTH & ARMOR STATS ==="},
        "maxhealth": {"type": "integer", "description": "Maximum health points", "default": 100},
        "starthealth": {"type": "integer", "description": "Starting health (-1 = maxhealth)", "default": -1},
        "maxarmor": {"type": "integer", "description": "Maximum armor points", "default": 0},
        "startarmor": {"type": "integer", "description": "Starting armor (-1 = maxarmor)", "default": -1},
        "forcepool": {"type": "integer", "description": "Maximum force pool", "default": 100},
        "forceregen": {"type": "number", "description": "Force regeneration multiplier", "default": 1.0},

        "_section_stats_speed": {"type": "null", "description": "=== SPEED & MOVEMENT ==="},
        "speed": {"type": "number", "description": "Movement speed multiplier", "default": 1.0},
        "baseSpeed": {"type": "integer", "description": "Base speed value override", "default": 0},

        "_section_multipliers": {"type": "null", "description": "=== STAT MULTIPLIERS ==="},
        "APmultiplier": {"type": "number", "description": "Ability Points multiplier", "default": 1.0},
        "BPmultiplier": {"type": "number", "description": "Block Points multiplier", "default": 1.0},
        "CSmultiplier": {"type": "number", "description": "Clash Strength multiplier", "default": 1.0},
        "ASmultiplier": {"type": "number", "description": "Attack Speed multiplier", "default": 1.0},
        "FPmultiplier": {"type": "number", "description": "Force Power multiplier", "default": 1.0},

        "_section_damage": {"type": "null", "description": "=== DAMAGE MODIFIERS ==="},
        "damageTaken": {"type": "number", "description": "Damage taken multiplier", "default": 1.0},
        "damageGiven": {"type": "number", "description": "Damage given multiplier", "default": 1.0},
        "rateOfFire": {"type": "number", "description": "Rate of fire multiplier", "default": 1.0},
        "rateOfFire_Melee": {"type": "number", "description": "Melee rate of fire multiplier", "default": 1.0},
        "knockbackTaken": {"type": "number", "description": "Knockback taken multiplier", "default": 1.0},
        "knockbackGiven": {"type": "number", "description": "Knockback given multiplier", "default": 1.0},
        "skillTimerMod": {"type": "number", "description": "Skill timer modifier", "default": 1.0},
        "hackRate": {"type": "number", "description": "Hacking rate modifier", "default": 1.0},

        "_section_melee": {"type": "null", "description": "=== MELEE CONFIGURATION ==="},
        "meleeknockback": {"type": "number", "description": "Melee knockback value", "default": 0.0},
        "meleeknockback_flat": {"type": "number", "description": "Flat melee knockback", "default": 0.0},
        "meleeknockback_mult": {"type": "number", "description": "Melee knockback multiplier", "default": 1.0},
        "meleeMoves": {"type": "string", "description": "Melee moveset (MeleeTable)"},
        "disableGunBash": {"type": "integer", "description": "Disable gun bash (0/1)", "default": 0},

        "_section_health_regen": {"type": "null", "description": "=== HEALTH REGENERATION ==="},
        "healthRegenAmount": {"type": "integer", "description": "HP regenerated per tick", "default": 0},
        "healthRegenRate": {"type": "integer", "description": "Time between regen ticks (ms)", "default": 0},
        "healthRegenCap": {"type": "integer", "description": "Max HP to regen to", "default": 0},

        "_section_armor_regen": {"type": "null", "description": "=== ARMOR REGENERATION ==="},
        "armourRegenAmount": {"type": "integer", "description": "Armor regenerated per tick", "default": 0},
        "armourRegenRate": {"type": "integer", "description": "Time between armor regen ticks (ms)", "default": 0},
        "armourRegenCap": {"type": "integer", "description": "Max armor to regen to", "default": 0},

        "_section_resource_regen": {"type": "null", "description": "=== RESOURCE REGENERATION (Jetpack/Cloak) ==="},
        "resourceRegenAmount": {"type": "integer", "description": "Resource regenerated per tick", "default": 0},
        "resourceRegenRate": {"type": "integer", "description": "Time between resource regen ticks (ms)", "default": 0},
        "resourceRegenCap": {"type": "integer", "description": "Max resource to regen to", "default": 0},

        "_section_block_regen": {"type": "null", "description": "=== BLOCK POINT REGENERATION ==="},
        "blockRegenAmount": {"type": "integer", "description": "BP regenerated per tick", "default": 0},
        "blockRegenRate": {"type": "integer", "description": "Time between BP regen ticks (ms)", "default": 0},
        "blockRegenCap": {"type": "integer", "description": "Max BP to regen to", "default": 0},

        "_section_rank_stats": {"type": "null", "description": "=== RANK-BASED STAT PROGRESSION (comma-separated per rank) ==="},
        "rankHealth": {"type": "string", "description": "Health per rank (r1,r2,r3)"},
        "rankArmor": {"type": "string", "description": "Armor per rank"},
        "rankForcePool": {"type": "string", "description": "Force pool per rank"},
        "rankForceRegen": {"type": "string", "description": "Force regen per rank"},
        "rankAP": {"type": "string", "description": "AP multiplier per rank"},
        "rankBP": {"type": "string", "description": "BP multiplier per rank"},
        "rankCS": {"type": "string", "description": "Clash strength per rank"},
        "rankAS": {"type": "string", "description": "Attack speed per rank"},
        "rankFP": {"type": "string", "description": "Force power per rank"},
        "rankROF": {"type": "string", "description": "Rate of fire per rank"},
        "rankSTM": {"type": "string", "description": "Skill timer mod per rank"},
        "rankHack": {"type": "string", "description": "Hack rate per rank"},
        "rankKbTaken": {"type": "string", "description": "Knockback taken per rank"},
        "rankKbGiven": {"type": "string", "description": "Knockback given per rank"},
        "rankDmgTaken": {"type": "string", "description": "Damage taken per rank"},
        "rankDmgGiven": {"type": "string", "description": "Damage given per rank"},
        "rankBaseSpeed": {"type": "string", "description": "Base speed per rank"},
        "rankSaberDamage": {"type": "string", "description": "Saber damage per rank"},
        "rankSaberThrowDamage": {"type": "string", "description": "Saber throw damage per rank"},
        "rankSaberMaxChain": {"type": "string", "description": "Max saber chain per rank"},
        "rankModelScale": {"type": "string", "description": "Model scale per rank"},
        "rankROFMelee": {"type": "string", "description": "Melee ROF per rank"},

        "_section_rank_regen": {"type": "null", "description": "=== RANK-BASED REGEN PROGRESSION ==="},
        "rankHealthRegenCap": {"type": "string", "description": "Health regen cap per rank"},
        "rankHealthRegenAmount": {"type": "string", "description": "Health regen amount per rank"},
        "rankHealthRegenRate": {"type": "string", "description": "Health regen rate per rank"},
        "rankArmourRegenCap": {"type": "string", "description": "Armor regen cap per rank"},
        "rankArmourRegenAmount": {"type": "string", "description": "Armor regen amount per rank"},
        "rankArmourRegenRate": {"type": "string", "description": "Armor regen rate per rank"},
        "rankResourceRegenCap": {"type": "string", "description": "Resource regen cap per rank"},
        "rankResourceRegenAmount": {"type": "string", "description": "Resource regen amount per rank"},
        "rankResourceRegenRate": {"type": "string", "description": "Resource regen rate per rank"},
        "rankBlockRegenCap": {"type": "string", "description": "Block regen cap per rank"},
        "rankBlockRegenAmount": {"type": "string", "description": "Block regen amount per rank"},
        "rankBlockRegenRate": {"type": "string", "description": "Block regen rate per rank"},

        "_section_animations": {"type": "null", "description": "=== ANIMATION OVERRIDES ==="},
        "runForward": {"type": "string", "description": "Forward run animation"},
        "runBackward": {"type": "string", "description": "Backward run animation"},
        "walkForward": {"type": "string", "description": "Forward walk animation"},
        "walkBackward": {"type": "string", "description": "Backward walk animation"},
        "deathAnim": {"type": "string", "description": "Death animation"},
        "tauntAnim": {"type": "string", "description": "Taunt animation"},
        "bowAnim": {"type": "string", "description": "Bow animation"},
        "meditateAnim": {"type": "string", "description": "Meditate animation"},
